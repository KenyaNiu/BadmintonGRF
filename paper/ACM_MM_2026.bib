  author = {Ishida, Tomoya and Ino, Takumi and Yamakawa, Yoshiki and Wada, Naofumi and Koshino, Yuta and Samukawa, Mina and Kasahara, Satoshi and Tohyama, Harukazu},
  year = 2024,
  month = apr,
  journal = {Physical Therapy Research},
  volume = {27},
