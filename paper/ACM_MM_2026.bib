  title = {Incidence of Injuries among Amateur Badminton Players: {{A}} Cross-Sectional Study},
  shorttitle = {Incidence of Injuries among Amateur Badminton Players},
  author = {{Marchena-Rodriguez}, Ana and {Gijon-Nogueron}, Gabriel and {Cabello-Manrique}, David and {Ortega-Avila}, Ana Belen},
